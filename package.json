{
  "name": "octogent",
  "version": "0.1.0",
  "description": "Web-first command surface for running multiple coding agents in parallel",
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "octogent": "./bin/octogent"
  },
  "scripts": {
    "start": "pnpm dev",
    "dev": "node scripts/dev.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "knip": "^6.3.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
